{
  "version": 2,
  "builds": [
    {
      "src": "server/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "emotion-app.html",
          "import-key-to-browser.html",
          "google-auth.config.js",
          "sel-data.v2.js",
          "school-resources.js",
          "university-list.js",
          "lib/**"
        ]
      }
    },
    { "src": "emotion-app.html", "use": "@vercel/static" },
    { "src": "import-key-to-browser.html", "use": "@vercel/static" },
    { "src": "google-auth.config.js", "use": "@vercel/static" },
    { "src": "sel-data.v2.js", "use": "@vercel/static" },
    { "src": "school-resources.js", "use": "@vercel/static" },
    { "src": "university-list.js", "use": "@vercel/static" },
    { "src": "lib/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "server/index.ts" },
    { "src": "/(.*)", "dest": "server/index.ts" }
  ]
}
