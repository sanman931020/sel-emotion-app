# ── Chat LLM Provider ──
# gemini | openai | anthropic | openrouter
CHAT_PROVIDER=gemini

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / ChatGPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic / Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OpenRouter — 單一金鑰可切換多種模型 (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Server
PORT=3000

# Google 登入（https://console.cloud.google.com/apis/credentials）
# 建立「OAuth 2.0 用戶端 ID」→ 類型：網頁應用程式
# 已授權的 JavaScript 來源：http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# 手機導向登入用（OAuth 用戶端 → 用戶端密鑰）
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# 自動寄送「分享給暖心支持對象」郵件（系統代寄，非草稿）
# 請使用可建立「應用程式密碼」的 Gmail；學校信箱若被禁用請改個人 Gmail
# 執行：powershell -ExecutionPolicy Bypass -File .\setup-smtp.ps1
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_16_char_app_password
# SMTP_FROM=心靈夥伴 <you@gmail.com>

# 開發者分析後端：Google 試算表（Apps Script Web App）
# 執行：powershell -ExecutionPolicy Bypass -File .\setup-google-sheets.ps1
# 或手動貼上部署後的網址：
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# 選用：Firebase Auth（若使用 Firebase 而非上方 GIS）
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_APP_ID=
